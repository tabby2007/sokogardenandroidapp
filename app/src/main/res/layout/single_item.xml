<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#D58CA5"
    android:layout_height="wrap_content">

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_margin="10dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="12dp">

<!--        Below is another linear layout that dictates how the contents will be aligned-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#D58CA5">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="Product Name"
                android:textSize="25sp"
                android:textStyle="bold|italic"
                android:textAlignment="center"
                android:textColor="#000"
                android:fontFamily="serif"/>

<!--            Below is our product_image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:id="@+id/product_photo"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="3dp"/>

<!--            Below is a textview for the product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="Kes.500"
                android:layout_marginTop="5sp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:textColor="#000"
                android:layout_marginLeft="10dp"/>

<!--            Below is the textview for the product_description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_description"
                android:text="The product description will appear here"
                android:textSize="20sp"
                android:textColor="#000"
                android:layout_marginLeft="10dp"
                android:textStyle="italic"
                android:layout_marginTop="3dp"/>

<!--            Below is the purchase button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:text="Purchase Now"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"
                android:textColor="#000"
                android:textSize="18dp"
                android:backgroundTint="#D3A1B2"/>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>