<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D3A1B2"
    tools:context=".MainActivity">

   <TextView
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:text="  ❇️ SokoGarden  ❇️"
       android:textSize="32sp"
       android:textAlignment="center"
       android:textStyle="bold|italic"
       android:fontFamily="cursive"
       android:background="@drawable/shape"
       android:padding="12dp"
       android:textColor="#1B1D2F"/>


<!--    Below is a linear layout that aligns contents horizontally-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤SIGNUP"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="4dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:textColor="#1B1D2F"
            android:backgroundTint="#EBE9F6"
            android:id="@+id/signupBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👮🏽SIGNIN"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:textColor="#1B1D2F"
            android:backgroundTint="#EBE9F6"
            android:id="@+id/signinBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 📜 About"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:textColor="#1B1D2F"
            android:backgroundTint="#EBE9F6"
            android:id="@+id/aboutbtn"/>


        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="24sp"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="10dp"
            android:backgroundTint="#ED0909"
            android:textColor="#F2F2F2"
            android:visibility="gone"/>



    </LinearLayout>


<!--    Below is our progress bar-->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/progressbar"/>




<!--    Below is our recycler bin-->
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/recyclerView"
        tools:listitem="@layout/single_item"/>


</LinearLayout>