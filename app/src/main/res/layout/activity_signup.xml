<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D3A1B2"
    tools:context=".Signup">

    <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Signup"
    android:textSize="45sp"
    android:textAlignment="center"
    android:textStyle="bold|italic"
    android:background="@drawable/shape"
    android:padding="12dp"
    android:textColor="#1B1D2F"/>

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">


<!--            Below is the EditText for username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 👤 Enter Your Username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#D58CA5"
                android:padding="10dp"/>

 <!--            Below is the EditText for email-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 📧 Enter Your Email Address"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:layout_margin="8dp"
                android:inputType="textEmailAddress"
                android:background="#D58CA5"
                android:padding="10dp"/>

 <!--            Below is the EditText for password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 🔑 Enter Your Password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:layout_margin="8dp"
                android:inputType="textPassword"
                android:background="#D58CA5"
                android:padding="10dp"/>

<!--            Below is the EditText for phone number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=" 📞 Enter Your Phone number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:layout_margin="8dp"
                android:inputType="number"
                android:background="#D58CA5"
                android:padding="10dp"/>

<!--            Below is the signup button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤SIGNUP"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="25dp"
                android:textColor="#1B1D2F"
                android:backgroundTint="#D3A1B2"
                android:id="@+id/signupBtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already have an Account? Login"
                android:textAlignment="center"
                android:textSize="22sp"
                android:layout_marginTop="12dp"
                android:textColor="#000"
                android:id="@+id/signintxt"/>


        </LinearLayout>


    </androidx.cardview.widget.CardView>





</LinearLayout>